### Retrieve Student Details

```sql
SELECT * FROM students;

### Filter Students by City

```sql
SELECT *
FROM students
WHERE city = 'Chennai';


### Maximum Course Fee


SELECT course_name,
MAX(fee)
FROM courses
GROUP BY course_name;

### INNER JOIN

```sql
SELECT
s.name,
e.course_id
FROM students s
INNER JOIN enrollments e
ON s.stu_id = e.stu_id;
```

---

### LEFT JOIN


SELECT
s.name,
e.course_id
FROM students s
LEFT JOIN enrollments e
ON s.stu_id = e.stu_id;


### RIGHT JOIN


SELECT
s.name,
c.course_name
FROM students s
RIGHT JOIN courses c
ON s.course_id = c.course_id;


### Subquery


SELECT name
FROM students
WHERE stu_id IN
(
SELECT stu_id
FROM enrollments
WHERE course_id = 101
);


